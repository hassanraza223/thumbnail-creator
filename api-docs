        <section id="get-thumbnail">
            <h2>Fetch Max Resolution Thumbnail</h2>
            <p>Pass any valid streaming target node parameters to resolve the primary media asset signature file reference instantly.</p>
            
            <div class="api-grid">
                <div>
                    <div style="margin-bottom: 20px;">
                        <span class="method-badge">GET</span>
                        <span class="endpoint-url">https://img.youtube.com/vi/{video_id}/maxresdefault.jpg</span>
                    </div>
                    
                    <h4>Query Parameters</h4>
                    <table class="param-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Type</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="param-name">video_id</td>
                                <td class="param-type">string</td>
                                <td>The isolated alphanumeric tracking sequence extracted from the target stream link.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div>
                    <div class="code-header">Example Request Node</div>
                    <pre class="code-block">
// Fetching High Definition Asset
fetch('https://img.youtube.com/vi/dQw4w9WgXcQ/maxresdefault.jpg')
  .then(response => {
    if(response.ok) {
       console.log("HD Image Payload Active");
    }
  });
                    </pre>
                </div>
            </div>
        </section>

