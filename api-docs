        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Plus Jakarta Sans', sans-serif; }
        body { background-color: var(--bg-dark); color: var(--text-light); line-height: 1.6; display: flex; }

        /* SIDEBAR NAVIGATION */
        .api-sidebar {
            width: 280px;
            height: 100vh;
            background: #0b0f19;
            border-right: 1px solid var(--border);
            position: fixed;
            padding: 30px 20px;
            overflow-y: auto;
        }

        .sidebar-brand { font-size: 20px; font-weight: 800; color: #fff; text-decoration: none; display: block; margin-bottom: 40px; }
        .sidebar-brand span { color: var(--primary); }
        
        .sidebar-menu h4 { font-size: 12px; uppercase; color: var(--text-muted); letter-spacing: 1px; margin-bottom: 15px; text-transform: uppercase; }
        .sidebar-menu ul { list-style: none; margin-bottom: 30px; }
        .sidebar-menu ul li { margin-bottom: 10px; }
        .sidebar-menu ul li a { color: var(--text-light); text-decoration: none; font-size: 14px; font-weight: 500; display: block; padding: 8px 12px; border-radius: 6px; transition: 0.2s; }
        .sidebar-menu ul li a:hover, .sidebar-menu ul li a.active { background: rgba(99, 102, 241, 0.15); color: var(--primary); }

        /* MAIN CONTENT AREA */
        .api-content { margin-left: 280px; padding: 60px 5%; width: calc(100% - 280px); max-width: 1200px; }
        
        .method-badge { background: var(--accent-green); color: #fff; padding: 4px 8px; border-radius: 4px; font-size: 12px; font-weight: 700; font-family: 'Fira Code', monospace; display: inline-block; margin-right: 10px; }
        .endpoint-url { font-family: 'Fira Code', monospace; color: var(--text-muted); background: #1f2937; padding: 6px 12px; border-radius: 6px; font-size: 14px; }

        h1 { font-size: 36px; font-weight: 800; margin-bottom: 15px; }
        h2 { font-size: 24px; font-weight: 700; margin-top: 40px; margin-bottom: 20px; border-bottom: 1px solid var(--border); padding-bottom: 10px; }
        p { color: var(--text-muted); margin-bottom: 20px; font-size: 15px; }

        .api-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-top: 20px; }
        @media (max-width: 968px) { .api-grid { grid-template-columns: 1fr; } .api-sidebar { display: none; } .api-content { margin-left: 0; width: 100%; } }

        /* PARAMETERS TABLE */
        .param-table { width: 100%; border-collapse: collapse; margin-top: 15px; }
        .param-table th, .param-table td { padding: 12px; text-align: left; border-bottom: 1px solid var(--border); }
        .param-table th { color: #fff; font-size: 14px; text-transform: uppercase; }
        .param-table td { font-size: 14px; }
        .param-name { font-family: 'Fira Code', monospace; color: var(--primary); font-weight: 600; }
        .param-type { font-family: 'Fira Code', monospace; color: var(--text-muted); font-size: 12px; }

        /* CODE BLOCK ENVIRONMENT */
        .code-block { background: #0b0f17; border: 1px solid var(--border); border-radius: 12px; padding: 20px; font-family: 'Fira Code', monospace; font-size: 13px; color: #34d399; overflow-x: auto; max-height: 400px; }
        .code-header { color: var(--text-muted); font-size: 11px; text-transform: uppercase; margin-bottom: 10px; border-bottom: 1px solid var(--border); padding-bottom: 5px; font-family: sans-serif; }
